# ArcReflex environment template
# Copy to .env and fill real values for local/dev deploys.
# PowerShell: Copy-Item .env.example .env

# --- Orchestrator core ---
ORCHESTRATOR_WALLET=0x0000000000000000000000000000000000000001
ORCHESTRATOR_PRIVKEY=0xaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
QUALITY_THRESHOLD=0.70
EVIDENCE_PATH=evidence.json
JUDGE_ARTIFACT_DIR=artifacts/judge
REPUTATION_PENALTY_ON_SWITCH=15
MIN_AGENT_REPUTATION=10

# --- Agent service discovery (orchestrator -> agents) ---
SEARCH_A_URL=http://localhost:8001
SEARCH_B_URL=http://localhost:8002
FILTER_A_URL=http://localhost:8003
FILTER_B_URL=http://localhost:8004

# --- Agent wallets ---
SEARCH_A_WALLET=0x0000000000000000000000000000000000000002
SEARCH_B_WALLET=0x0000000000000000000000000000000000000003
FILTER_A_WALLET=0x0000000000000000000000000000000000000004
FILTER_B_WALLET=0x0000000000000000000000000000000000000005

# --- Payments / x402 / Arc chain ---
CIRCLE_API_KEY=
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/w3s
ARC_CHAIN_ID=1234567
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
ARCREFLEX_STRICT_X402=true
ARCREFLEX_ALLOW_INSECURE_DEMO=false

# --- Live inference configuration (optional but recommended) ---
ARCREFLEX_LIVE_INFERENCE=false
ARCREFLEX_MODEL_API_URL=
ARCREFLEX_MODEL_API_KEY=
ARCREFLEX_MODEL=gpt-4o-mini
ARCREFLEX_MODEL_TIMEOUT_SECONDS=12
ARCREFLEX_ENABLE_WEB_SEARCH=true
ARCREFLEX_WEB_SEARCH_TIMEOUT_SECONDS=8
ARCREFLEX_SEARCH_MODEL_MAX_RESULTS=8
ARCREFLEX_FILTER_MODEL_SAMPLE_EVERY=4
ARCREFLEX_FILTER_MODEL_MAX_ITEMS=80

# --- Contract/deploy helpers ---
ARC_RPC_URL=https://rpc.arc.circle.com
AGENT_REGISTRY_ADDR=0x0000000000000000000000000000000000000000

# --- Frontend (optional deployment envs) ---
# Current UI may still use hardcoded localhost endpoints unless patched.
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws
